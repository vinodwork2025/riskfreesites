{
  "name": "riskfreesites",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "pages:build": "npx opennextjs-cloudflare build",
    "pages:deploy": "npx wrangler pages deploy .open-next/assets",
    "db:migrate": "npx wrangler d1 execute riskfreesites-db --file=migrations/0001_init.sql",
    "db:migrate:remote": "npx wrangler d1 execute riskfreesites-db --remote --file=migrations/0001_init.sql"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "@cloudflare/workers-types": "^4.20240512.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^4.65.0"
  }
}
