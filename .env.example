# Resend API (email delivery)
RESEND_API_KEY=re_your_key_here

# From address for outgoing emails (must be verified in Resend)
FROM_EMAIL=hello@riskfreesites.com

# Your reply-to address
REPLY_TO_EMAIL=yourname@yourdomain.com

# Base URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://riskfreesites.com

# Admin secret for /api/leads endpoint
ADMIN_SECRET=change_me_to_a_long_random_string
